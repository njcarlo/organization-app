{
  "name": "hae-platform",
  "private": true,
  "version": "0.1.0",
  "description": "HAE platform monorepo — one app per milestone module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @hae/operating-tracker",
    "dev:tracker": "npm run dev -w @hae/operating-tracker",
    "dev:lms": "npm run dev -w @hae/lms",
    "dev:eir": "npm run dev -w @hae/eir",
    "dev:crm": "npm run dev -w @hae/crm",
    "dev:ams": "npm run dev -w @hae/ams",
    "build": "npm run build -w @hae/operating-tracker",
    "build:tracker": "npm run build -w @hae/operating-tracker",
    "build:lms": "npm run build -w @hae/lms",
    "build:eir": "npm run build -w @hae/eir",
    "build:crm": "npm run build -w @hae/crm",
    "build:ams": "npm run build -w @hae/ams",
    "build:all": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "deploy": "npm run build:tracker && firebase deploy --only hosting,firestore:rules,auth",
    "deploy:hosting": "npm run build:tracker && firebase deploy --only hosting"
  },
  "devDependencies": {
    "firebase-tools": "^15.22.4"
  },
  "engines": {
    "node": ">=20"
  }
}
