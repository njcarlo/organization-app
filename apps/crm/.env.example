# EmailJS config for automatic @mention emails (no Cloud Functions / Blaze required).
# Create a free account at https://www.emailjs.com, add an email service + template,
# then copy the three IDs below into a local .env.local (gitignored via *.local).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
