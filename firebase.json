{
  "hosting": [
    {
      "target": "tracker",
      "public": "apps/operating-tracker/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public,max-age=31536000,immutable"
            }
          ]
        }
      ]
    },
    {
      "target": "tracker-legacy",
      "public": "apps/operating-tracker/dist",
